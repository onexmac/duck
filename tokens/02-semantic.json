      "elevated": { "$type": "color", "$value": "{color.white}" },
      "subtle":   { "$type": "color", "$value": "{color.neutral.100}" },
      "inverse":  { "$type": "color", "$value": "{color.neutral.900}" }
    },

    "text": {
      "primary":   { "$type": "color", "$value": "{color.neutral.900}" },
