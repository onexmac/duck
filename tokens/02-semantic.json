{
  "color": {
    "bg": {
      "page":     { "$type": "color", "$value": "{color.duck.page-bg}" },
      "surface":  { "$type": "color", "$value": "{color.duck.card}" },
      "elevated": { "$type": "color", "$value": "{color.white}" },
      "subtle":   { "$type": "color", "$value": "{color.duck.muted-50}" },
      "inverse":  { "$type": "color", "$value": "{color.duck.dark}" }
    },

    "text": {
      "primary":    { "$type": "color", "$value": "{color.duck.dark}" },
      "secondary":  { "$type": "color", "$value": "{color.duck.dark-500}" },
      "muted":      { "$type": "color", "$value": "{color.duck.muted}" },
      "inverse":    { "$type": "color", "$value": "{color.white}" },
      "link":       { "$type": "color", "$value": "{color.duck.blue}" },
      "link-hover": { "$type": "color", "$value": "{color.duck.blue-hover}" },
      "danger":     { "$type": "color", "$value": "{color.red.600}" },
      "success":    { "$type": "color", "$value": "{color.green.600}" },
      "warning":    { "$type": "color", "$value": "{color.duck.yellow}" }
    },

    "border": {
      "default": { "$type": "color", "$value": "{color.neutral.200}" },
      "strong":  { "$type": "color", "$value": "{color.duck.disabled}" },
      "subtle":  { "$type": "color", "$value": "{color.neutral.100}" },
      "focus":   { "$type": "color", "$value": "{color.duck.blue}" },
      "danger":  { "$type": "color", "$value": "{color.red.500}" }
    },

    "interactive": {
      "primary":          { "$type": "color", "$value": "{color.duck.yellow}" },
      "primary-hover":    { "$type": "color", "$value": "{color.duck.yellow-hover}" },
      "primary-active":   { "$type": "color", "$value": "{color.duck.yellow-active}" },
      "primary-text":     { "$type": "color", "$value": "{color.duck.dark}" },
      "secondary":        { "$type": "color", "$value": "{color.duck.muted-50}" },
      "secondary-hover":  { "$type": "color", "$value": "{color.neutral.200}" },
      "secondary-active": { "$type": "color", "$value": "{color.neutral.300}" },
      "secondary-text":   { "$type": "color", "$value": "{color.duck.dark}" },
      "ghost-hover":      { "$type": "color", "$value": "{color.duck.muted-50}" }
    },

    "feedback": {
      "success":    { "$type": "color", "$value": "{color.green.600}" },
      "success-bg": { "$type": "color", "$value": "{color.green.50}" },
      "warning":    { "$type": "color", "$value": "{color.duck.yellow-hover}" },
      "warning-bg": { "$type": "color", "$value": "{color.duck.yellow-100}" },
      "error":      { "$type": "color", "$value": "{color.red.600}" },
      "error-bg":   { "$type": "color", "$value": "{color.red.50}" },
      "info":       { "$type": "color", "$value": "{color.duck.blue}" },
      "info-bg":    { "$type": "color", "$value": "{color.blue.50}" }
    },

    "brand": {
      "yellow":   { "$type": "color", "$value": "{color.duck.yellow}" },
      "dark":     { "$type": "color", "$value": "{color.duck.dark}" },
      "muted":    { "$type": "color", "$value": "{color.duck.muted}" },
      "blue":     { "$type": "color", "$value": "{color.duck.blue}" },
      "coral":    { "$type": "color", "$value": "{color.duck.coral}" },
      "teal":     { "$type": "color", "$value": "{color.duck.teal}" },
      "indigo":   { "$type": "color", "$value": "{color.duck.indigo}" },
      "disabled": { "$type": "color", "$value": "{color.duck.disabled}" }
    }
